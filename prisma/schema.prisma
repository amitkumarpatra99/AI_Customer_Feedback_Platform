// prisma/schema.prisma
// Project LOOP - AI Customer Feedback Intelligence Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// WORKSPACE (Multi-tenant company/organization)
// ============================================
model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users     User[]
  feedbacks Feedback[]
  themes    Theme[]
  reports   Report[]

  @@map("workspaces")
}

// ============================================
// USER (Team members with roles)
// ============================================
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(VIEWER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  generatedReports Report[] @relation("ReportGenerator")

  @@map("users")
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

// ============================================
// FEEDBACK (Customer feedback items)
// ============================================
model Feedback {
  id             String     @id @default(cuid())
  content        String     // The actual feedback text
  channel        Channel    // Source: SUPPORT, APP_STORE, etc.
  sourceRef      String?    // External reference (e.g., ticket ID)
  customerLabel  String?    // e.g., "Enterprise", "Free Tier"
  
  // AI Classification
  sentiment      Sentiment  @default(NEUTRAL)
  sentimentScore Float      @default(0.0) // -1.0 to 1.0
  featureArea    String?    // e.g., "Checkout", "Onboarding"
  aiRationale    String?    // Why AI classified it this way
  
  // Workflow
  status         Status     @default(NEW)
  
  // Timestamps
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  themes         FeedbackTheme[]
  // embedding      Embedding?

  // Indexes for fast filtering
  @@index([workspaceId, status])
  @@index([workspaceId, sentiment])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, channel])
  @@map("feedbacks")
}

enum Channel {
  SUPPORT_TICKET
  APP_STORE
  NPS_SURVEY
  SALES_CALL
  COMMUNITY
  OTHER
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum Status {
  NEW
  REVIEWED
  ACTIONED
}

// ============================================
// THEME (AI-discovered topics/categories)
// ============================================
model Theme {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1") // Hex color for UI
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  feedbacks   FeedbackTheme[]

  @@unique([workspaceId, name]) // Same theme name can't exist twice in a workspace
  @@map("themes")
}

// ============================================
// FEEDBACK_THEME (Join table: Many-to-Many)
// ============================================
model FeedbackTheme {
  feedbackId String
  themeId    String
  confidence Float    @default(1.0) // AI confidence score (0-1)
  
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme      Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
  @@map("feedback_themes")
}


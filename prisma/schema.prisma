datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Sentiment {
  POS
  NEU
  NEG
}

enum Status {
  NEW
  REVIEWED
  ACTIONED
}

model Workspace {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  users     User[]
  feedback  Feedback[]
  themes    Theme[]
  reports   Report[]
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(VIEWER)
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reports      Report[]
  createdAt    DateTime   @default(now())
}

model Feedback {
  id            String          @id @default(cuid())
  content       String
  channel       String          // e.g. "Support ticket", "App store review", etc.
  sourceRef     String?
  customerLabel String?
  sentiment     Sentiment       @default(NEU)
  sentimentScore Float          @default(0) // -1.0 to 1.0
  status        Status          @default(NEW)
  createdAt     DateTime        @default(now())
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  themes        FeedbackTheme[]
  embedding     Embedding?
}

model Theme {
  id          String          @id @default(cuid())
  name        String
  description String?
  color       String          @default("#3b82f6")
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedbacks   FeedbackTheme[]
}

model FeedbackTheme {
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  themeId    String
  theme      Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  confidence Float    @default(1.0) // 0.0 to 1.0

  @@id([feedbackId, themeId])
}

model Embedding {
  id         String   @id @default(cuid())
  feedbackId String   @unique
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  // Float array to store the vector embeddings (or can use Unsupported("vector(1536)") if pgvector is enabled)
  vector     Float[]
}

model Report {
  id          String    @id @default(cuid())
  title       String
  periodStart DateTime
  periodEnd   DateTime
  contentJson String
  createdAt   DateTime  @default(now())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  generatedBy String
  user        User      @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
}
